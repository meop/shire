{
  "name": "@meop/shire",
  "version": "0.2.0",
  "exports": {
    "./sh": "./src/sh.ts",
    "./sh/nu": "./src/sh/nu.ts",
    "./sh/pwsh": "./src/sh/pwsh.ts",
    "./sh/zsh": "./src/sh/zsh.ts",
    "./cmd": "./src/cmd.ts",
    "./ctx": "./src/ctx.ts",
    "./env": "./src/env.ts",
    "./path": "./src/path.ts",
    "./reg": "./src/reg.ts",
    "./serde": "./src/serde.ts",
    "./srv": "./src/srv.ts"
  },
  "imports": {
    "@eemeli/yaml": "jsr:@eemeli/yaml@^2.8.2",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "fmt": {
    "lineWidth": 120,
    "semiColons": false,
    "singleQuote": true,
    "trailingCommas": "onlyMultiLine"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "check": "deno check src/**/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-all tests/"
  }
}
