{
  "name": "@meop/shire",
  "version": "0.7.3",
  "description": "Shell Interface Renderer — renders dynamic web-based command-line user interfaces for shells",
  "exports": {
    "./cmd": "./src/cmd.ts",
    "./ctx": "./src/ctx.ts",
    "./env": "./src/env.ts",
    "./reg": "./src/reg.ts",
    "./serde": "./src/serde.ts",
    "./sh": "./src/sh.ts",
    "./sh/nu": "./src/sh/nu.ts",
    "./sh/pwsh": "./src/sh/pwsh.ts",
    "./sh/zsh": "./src/sh/zsh.ts",
    "./srv": "./src/srv.ts"
  },
  "fmt": {
    "exclude": ["**/*.yaml", "**/*.yml", "**/*.jsonc", "**/*.json"],
    "lineWidth": 120,
    "semiColons": false,
    "singleQuote": true,
    "trailingCommas": "onlyMultiLine"
  },
  "imports": {
    "@eemeli/yaml": "jsr:@eemeli/yaml@^2.8.3",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "check": "deno check src/**/*.ts",
    "format": "deno fmt",
    "format:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-all src/"
  }
}
